samples/UnidoteUnityDemo/*.sln

# --- Godot sample generated folders ---
samples/UnidoteGodotDemo/.godot/
samples/UnidoteGodotDemo/.import/
samples/UnidoteGodotDemo/.mono/

# --- IDE ---
.vs/
.vscode/
.idea/
