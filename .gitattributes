* text=auto eol=lf

# --- Auto-generated mirrors of src/Unidote.Core ---
# Marks these paths as generated so GitHub collapses them in PR diffs and
# excludes them from language statistics. Edits belong in src/Unidote.Core
# only.
src/Unidote.Unity/Runtime/Core/**                    linguist-generated=true
src/Unidote.Godot/addons/Unidote/Core/**             linguist-generated=true
samples/UnidoteUnityDemo/Packages/com.shilo.unidote/Runtime/Core/**  linguist-generated=true
samples/UnidoteGodotDemo/addons/Unidote/Core/**      linguist-generated=true

# Shell scripts must stay LF — breaks on Windows CRLF otherwise.
*.sh            text eol=lf
*.bash          text eol=lf

# PowerShell expects CRLF on Windows.
*.ps1           text eol=crlf
*.psm1          text eol=crlf

# Binary assets (if added later).
*.png           binary
*.jpg           binary
*.jpeg          binary
*.gif           binary
*.ico           binary
*.svg           text
*.ttf           binary
*.otf           binary
*.fbx           binary
*.psd           binary
*.wav           binary
*.mp3           binary
*.ogg           binary

# Unity keeps meta/YAML as text; force LF for cross-platform stability.
*.meta          text eol=lf
*.asmdef        text eol=lf
*.unity         text eol=lf
*.prefab        text eol=lf
*.mat           text eol=lf
*.controller    text eol=lf

# Godot scene/resource files are text.
*.tscn          text eol=lf
*.tres          text eol=lf
*.gd            text eol=lf
*.godot         text eol=lf
*.cfg           text eol=lf
*.uid           text eol=lf
